<% layout("/layouts/boilerplate") %>
<body>
   <br>
    <div class="row">
        <div class="col-8 offset-2">
     <h3>Create New Listing:</h3>
      <form method="post" action="/listings" novalidate class="needs-validation">
        <div class="mb-3">
            <label for="title" class="form-label">Title: </label><br>
        <input name="listing[title]" type="text" placeholder="enter your title" class="form-control" required>
        <div class="valid-feedback">Title looks good</div>
        <div class="valid-feedback"></div>
        <div class="invalid-feedback">Title should be valid</div>
    </div>
        
        <div class="mb-3">
            <label for="description" class="form-label">Description: </label><br>
        <textarea name="listing[description]" id="" class="form-control" required></textarea>
        <div class="valid-feedback"></div>
        <div class="invalid-feedback">Description should be valid</div>
    </div>
        
        <div class="mb-3">
        <label for="image" class="form-label">URL</label><br>
        <input name="listing[image][url]" type="text" placeholder="enter image URL/Link" class="form-control" required>
        <div class="valid-feedback"></div>
        <div class="invalid-feedback">URL should be valid</div>
    </div>
        
        <div class="mb-3">
        <label for="price" class="form-label">Price: </label><br>
        <input name="listing[price]" type="number" placeholder="enter your price" class="form-control" required>
        <div class="valid-feedback"></div>
        <div class="invalid-feedback">Price should be valid</div>
    </div>
        
        <div class="row">
        <div class="mb-3 col-md-4">
        <label for="location" class="form-label">Location: </label><br>
        <input name="listing[location]" type="text" placeholder="location" class="form-control" required>
        <div class="valid-feedback"></div>
        <div class="invalid-feedback">Please enter  location name</div>
   
    </div>
        
        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Country</label><br>
        <input name="listing[country]" type="text" placeholder="enter your coutry" class="form-control" required>
        <div class="valid-feedback"></div>
        <div class="invalid-feedback">Please enter  Country name</div>
    </div>
        </div>
        <br>
        <button class="btn btn-dark add-btn">Add</button>
        <br><br>
    </form>
    </div>
    </div>
</body>
